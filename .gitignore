# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp

# マシン固有の証明書（Norton等のHTTPS検査ルートCA）— 各自の環境で生成
.devcontainer/certs/

# Dependencies (将来 npm 等を使う場合)
node_modules/

# Build output (将来 Next.js 等)
.next/
out/
dist/

# Cloudflare wrangler ローカルキャッシュ
.wrangler/

# ローカル開発用シークレット（Discord Client Secret 等。.dev.vars.example を参照して各自作成）
.dev.vars

# Logs / temp
*.log
# スキャフォルドの参照ファイル（.txt 有無どちらも無視）
scratch_ref_*
# 作業用ファイル置き場（計画メモ・スクリーンショット等。コミット対象外）
tmp/

# Claude Code のローカル権限設定（個人環境依存。共有用は settings.json）
.claude/settings.local.json
