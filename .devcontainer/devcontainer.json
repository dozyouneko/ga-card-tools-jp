{
  // Grand Archive 日本語カードDB — Dev Container 定義
  // 純静的サイト（現状）＋ 将来の Next.js 移行を見据えた Node LTS 環境。
  "name": "ga-card-tools-jp",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20-bookworm",

  // 3000 = 静的プレビュー（scripts/serve.mjs）／将来の `next dev`
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": { "label": "static / next dev", "onAutoForward": "notify" }
  },

  // 依存が増えたら自動で入るように（現状は devDependencies 空なので実質no-op）
  // + Claude Code CLI をコンテナ作成時にグローバルインストール
  // + Norton の HTTPS スキャン用ルート証明書をシステム信頼ストアに登録（curl/git/openssl 対策）
  "postCreateCommand": "npm install --no-audit --no-fund || true; npm install -g @anthropic-ai/claude-code || true; if [ -f .devcontainer/certs/norton-root.crt ]; then sudo cp .devcontainer/certs/norton-root.crt /usr/local/share/ca-certificates/norton-root.crt && sudo update-ca-certificates; fi || true",

  // Node は OS の証明書ストアを見ないため、Norton ルートCAを個別に教える（Claude CLI / npm の SSL エラー対策）
  "remoteEnv": {
    "NODE_EXTRA_CA_CERTS": "${containerWorkspaceFolder}/.devcontainer/certs/norton-root.crt"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.live-server"
      ],
      "settings": {
        "files.eol": "\n",
        "editor.formatOnSave": false,
        "terminal.integrated.defaultProfile.linux": "bash",
        "workbench.panel.defaultLocation": "right"
      }
    }
  },

  "remoteUser": "node"
}
