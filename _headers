# Netlify / Cloudflare Pages 用セキュリティヘッダ（より具体的なパスを先に記述）

# 印刷PDFツール: 外部通信なし。厳格な self-only CSP。
/tools/print/*
  Content-Security-Policy: default-src 'self'; img-src 'self' data: blob:; script-src 'self'; style-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# jsPDFは遅延読み込み(#22)。90日で1回しか変わっていないベンダーライブラリのため長期キャッシュする。
# ⚠️ 差し替えるときは必ずファイル名を変えること(このヘッダのままだと更新が届かない)
/shared/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# 大会デッキのHTML断片: 単独のページではなくダイアログ表示用の部品のため、検索エンジンには載せない。
# Pagesは /foo.html を /foo へ308でトリムするため、トリム後のパスにも同じ指定が要る
# (.html 側だけだと実際に本文を返すURLにヘッダが付かない)。
/tournaments/*/decks.html
  X-Robots-Tag: noindex
/tournaments/*/decks
  X-Robots-Tag: noindex

# カードDB（ルート）: 公式API api.gatcg.com と Cloudflare Web Analytics のみ通信を許可。
# img-src の cdn.discordapp.com はデッキ構築ツールのDiscordアバター用。
# (Pagesは一致した全ルールのCSPヘッダを重複して送り積集合で効くため、
#  パス別ルールに書いても /* 側で許可しない限りブロックされる。ここで許可するのが確実)
/*
  Content-Security-Policy: default-src 'self'; img-src 'self' data: blob: https://api.gatcg.com https://cdn.discordapp.com; connect-src 'self' https://api.gatcg.com https://cloudflareinsights.com; script-src 'self' https://static.cloudflareinsights.com; style-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()
